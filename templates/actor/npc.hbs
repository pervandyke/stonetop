<form class="{{cssClass}} stonetop-follower-card" autocomplete="off">
	<div class="sheet-wrapper">
		<div>
			{{> "stonetop.actor-header"}}

			<section class="flexrow">
				<div>
					<section>
						<div class="stonetop-npc-attrs stonetop-follower-attrs">
							<div class="cell cell--damage cell--Roll">
								<span class="cell__title">{{localize "stonetop.followers.damage"}}</span>
								<div class="flexrow">
									<div class="attr-rollable rollable" data-roll="{{stonetop.damage}}"><i class="fas fa-dice-d6"></i></div>
									<input id="npc-damage" type="text" class="stonetop-follower-damage" value="{{stonetop.damage}}" data-slug="{{slug}}">
								</div>								
							</div>
							<div class="cell cell--hp cell--Resource">
								<span class="cell__title">{{localize "stonetop.followers.hp"}}</span>
								<div class="cell__counter">
									<input id="npc-hp" type="number" class="stonetop-follower-hp" min="0" value="{{stonetop.hp}}" data-slug="{{slug}}">
									<span>/</span>
									<input id="npc-max-hp" type="number" class="stonetop-follower-hp-max" min="0" value="{{stonetop.hpMax}}" data-slug="{{slug}}">
								</div>
							</div>
							<div class="cell cell--armor cell--Number">
								<span class="cell__title">{{localize "stonetop.followers.armor"}}</span>
								<input id="npc-armor" type="number" class="stonetop-follower-armor" min="0" value="{{stonetop.armor}}" data-slug="{{slug}}">
							</div>
						</div>
					</section>

					<section>
						<div class="flexcolumn">
							<div>
								<span class="stonetop-follower-label">Instinct</span>
								<input id="npc-instinct" class="stonetop-follower-metadata-input" type="text" value="{{stonetop.instinct}}">
							</div>
							<div>
								<span class="stonetop-follower-label">Special Qualities</span>
								<input id="npc-special-qualities" class="stonetop-follower-metadata-input" type="text" value="{{stonetop.qualities}}">
							</div>
						</div>
					</section>
				</div>
			</section>

		</div>

		<section class="flexcol">
			{{#if stonetop.moves}}
			<div>
				<span class="stonetop-follower-label">{{localize "stonetop.followers.moves"}}</span>
				<div style="min-height: 50px;">

				</div>
			</div>
			{{/if}}
			<span class="stonetop-follower-label">{{localize "stonetop.followers.description"}}</span>
			<textarea class="stonetop-follower-description-textarea stonetop-notes st-notes-textarea" type="text" placeholder="" data-slug="{{slug}}" >{{stonetop.description}}</textarea>
		</section>

	</div>
</form>