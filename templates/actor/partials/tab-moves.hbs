<div class="tab moves" data-group="primary" data-tab="moves">
	<section class="sheet-tab">

		{{!-- Roll Mode --}}
		{{#if isCharacter}}
		{{#if (not sheetSettings.hideRollMode)}}
		<section class="sheet-resources flexrow">
			<div class="cell cell--roll-mode">
				<label class="cell__title">{{localize "PBTA.RollMode"}}</label>
				{{radioBoxes 'flags.pbta.rollMode' config.rollModes checked=flags.pbta.rollMode localize=true}}
			</div>
		</section>
		{{/if}}
		{{/if}}

		{{#if stonetop.movelist.playbookMoves.length}}
				<div class="stonetop-move-group">
					{{> "stonetop.section-heading" title=(localize "stonetop.character.moves.playbookMoves") note=stonetop.movelist.startingMovesNote}}
					<ol class="items-list">
					{{#each stonetop.movelist.playbookMoves}}
						{{#if (and owned rollType)}}
						<li class="item stonetop-item{{#if isStarting}} move-starting{{/if}}" data-item-id="{{ownedId}}">
						{{else}}
						<li class="stonetop-item{{#if locked}} move-locked{{/if}}{{#if isStarting}} move-starting{{/if}}">
						{{/if}}
							<div class="stonetop-item-header">
								{{#if repeatable}}
								<span class="stonetop-repeat-checks">
									{{#each (repeatChecks this)}}
									<input type="checkbox" class="stonetop-item-check stonetop-repeat-check"
									       data-compendium-id="{{../compendiumId}}"
									       data-owned-id="{{ownedId}}"
									       {{#if checked}}checked{{/if}}
									       {{#if disabled}}disabled{{/if}}>
									{{/each}}
								</span>
								{{else}}
								<input type="checkbox" class="stonetop-item-check stonetop-move-check"
								       data-compendium-id="{{compendiumId}}"
								       data-owned-id="{{ownedId}}"
								       {{#if owned}}checked{{/if}}
								       {{#if (or isStarting locked)}}disabled{{/if}}>
								{{/if}}
								<strong class="stonetop-item-name">{{name}}</strong>
								{{#if sourceLabel}}<span class="stonetop-item-source">{{sourceLabel}}</span>{{/if}}
								{{#if (and owned rollType)}}
								<span class="rollable move-rollable" data-roll="{{rollType}}" data-mod="">
									<i class="fas fa-dice-d6"></i>
								</span>
								{{/if}}
								{{#if (and owned resource)}}
								<span class="stonetop-item-resources">
									{{#each (resourceChecks resource)}}
									<span class="stonetop-item-resource-entry">
										<button type="button" class="stonetop-item-resource-check{{#if checked}} is-checked{{/if}}"
										        data-move-name="{{../name}}"
										        data-index="{{@index}}"></button>
										{{#if label}}<span class="stonetop-resource-label">{{label}}</span>{{/if}}
									</span>
									{{/each}}
								</span>
								{{/if}}
							</div>
							<div class="stonetop-item-description">{{{description}}}</div>
							{{#if requiresLabel}}<p class="stonetop-move-note">Requires: {{requiresLabel}}</p>{{/if}}
							{{#if requiresPlaybook}}<p class="stonetop-move-note">Requires {{requiresPlaybook}} playbook</p>{{/if}}
							{{#if minLevel}}<p class="stonetop-move-note">Level {{minLevel}}+</p>{{/if}}
						</li>
					{{/each}}
					</ol>
				</div>
			{{/if}}

		{{#each stonetop.movelist.otherGroups}}
				<div class="stonetop-move-group">
					<h3 class="stonetop-move-group-title">{{label}}</h3>
					<ol class="items-list">
					{{#each moves}}
						{{#if rollType}}
						<li class="item stonetop-item" data-item-id="{{ownedId}}">
						{{else}}
						<li class="stonetop-item">
						{{/if}}
							<div class="stonetop-item-header">
								{{#if rollType}}
								<span class="rollable move-rollable" data-roll="{{rollType}}" data-mod="">
									<i class="fas fa-dice-d6"></i>
								</span>
								{{/if}}
								<strong class="stonetop-item-name">{{name}}</strong>
								<a class="stonetop-other-move-delete" data-item-id="{{ownedId}}" title="{{localize 'stonetop.character.moves.removeMove'}}">
									<i class="fas fa-trash"></i>
								</a>
							</div>
						</li>
					{{/each}}
					</ol>
				</div>
				{{/each}}

			<div class="stonetop-move-group">
				{{> "stonetop.section-heading" title=(localize "stonetop.character.moves.otherMoves")}}
				<ol class="items-list">
				{{#each stonetop.movelist.otherMoves}}
					<li class="item stonetop-item" data-item-id="{{ownedId}}">
						<div class="stonetop-item-header">
							{{#if rollType}}
							<span class="rollable move-rollable" data-roll="{{rollType}}" data-mod="">
								<i class="fas fa-dice-d6"></i>
							</span>
							{{/if}}
							<strong class="stonetop-item-name">{{name}}</strong>
							<a class="stonetop-other-move-delete" data-item-id="{{ownedId}}" title="{{localize 'stonetop.character.moves.removeMove'}}">
								<i class="fas fa-trash"></i>
							</a>
						</div>
						{{#if description}}<div class="stonetop-item-description">{{{description}}}</div>{{/if}}
					</li>
				{{/each}}
				</ol>
				<button type="button" class="item-control item-create" data-type="move" data-move-type="other" title="{{localize 'stonetop.character.moves.addMove'}}">
					<i class="fas fa-plus"></i>
				</button>
			</div>

	</section>
</div>
