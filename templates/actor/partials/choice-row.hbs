{{#if (eq type "heading")}}
{{! Heading row }}
{{#if content.title}}{{> "stonetop.section-heading" title=content.title}}{{/if}}
{{#if track}}
<div class="stonetop-choice-track">
    <span class="stonetop-choice-track-checks">
        {{#each track.checks}}
        <input type="checkbox"
               class="stonetop-cg-track"
               data-cg-context="{{../cgContext}}"
               data-cg-group="{{../cgGroup}}"
               data-cg-option="{{../track.slug}}"
               data-cg-index="{{@index}}"
               {{#if this}}checked{{/if}}>
        {{/each}}
    </span>
    <span class="stonetop-choice-track-desc">{{{content.text}}}</span>
</div>
{{else if content.text}}
<div class="stonetop-choice-description">{{{content.text}}}</div>
{{/if}}
{{#if input}}
<div class="stonetop-choice-option stonetop-choice-option--text">
    <textarea class="stonetop-cg-text"
              data-cg-context="{{cgContext}}"
              data-cg-group="{{cgGroup}}"
              data-cg-option="{{input.slug}}"
              {{#if input.placeholder}}placeholder="{{input.placeholder}}"{{/if}}>{{input.value}}</textarea>
</div>
{{/if}}
{{else if (eq type "follower")}}
{{! Follower row (arcanum back) }}
<div class="stonetop-arcanum-follower">
    {{#if inlineDisplay}}
    {{#if track}}
    <input type="checkbox" class="stonetop-arcanum-follower-check"
           data-cg-context="{{cgContext}}"
           data-slug="{{cgGroup}}"
           data-option="{{slug}}"
           data-index="0"
           {{#if (lookup track.checks 0)}}checked{{/if}}>
    {{/if}}
    {{#if follower}}{{> "stonetop.follower-card" follower}}{{/if}}
    {{else if title}}
    <label class="stonetop-arcanum-follower-label">
        {{#if track}}
        <input type="checkbox" class="stonetop-arcanum-follower-check"
               data-cg-context="{{cgContext}}"
               data-slug="{{cgGroup}}"
               data-option="{{slug}}"
               data-index="0"
               {{#if (lookup track.checks 0)}}checked{{/if}}>
        {{/if}}
        {{{title}}}
    </label>
    {{/if}}
</div>
{{else}}
{{! Pick or track row (type="choice") }}
<div class="stonetop-choice-row{{#if inline}} stonetop-choice-row--inline{{/if}}">
    {{#each options}}
    {{#if description}}
    {{! Pick mode — card layout when option has a description }}
    <label class="stonetop-item{{#if checked}} is-checked{{/if}}">
        <div class="stonetop-item-header">
            <input type="{{#if ../radio}}radio{{else}}checkbox{{/if}}"
                   class="stonetop-item-check{{#if ../cgContext}} stonetop-cg-pick{{/if}}{{#unless ../cgContext}} {{../inputClass}}{{/unless}}"
                   {{#if ../radio}}name="{{../namePrefix}}-{{../rowKey}}"{{/if}}
                   {{#if ../cgContext}}
                   data-cg-context="{{../cgContext}}"
                   data-cg-group="{{../cgGroup}}"
                   data-cg-option="{{slug}}"
                   data-cg-siblings="{{../siblingSlugsCsv}}"
                   data-display-label="{{text}} — {{description}}"
                   {{else}}
                   {{#if ../possessionSlug}}data-possession-slug="{{../possessionSlug}}"{{/if}}
                   {{#if ../siblingSlugsCsv}}data-sibling-slugs-csv="{{../siblingSlugsCsv}}"{{/if}}
                   data-row-key="{{../rowKey}}"
                   data-choice-slug="{{slug}}"
                   {{/if}}
                   {{#if checked}}checked{{/if}}>
            <strong class="stonetop-item-name">{{text}}</strong>
        </div>
        <div class="stonetop-item-description">{{description}}</div>
    </label>
    {{else}}
    {{! Pick mode — inline (no description) }}
    <label class="stonetop-choice-option-label{{#if checked}} is-checked{{/if}}">
        <input type="{{#if ../radio}}radio{{else}}checkbox{{/if}}"
               class="stonetop-item-check{{#if ../cgContext}} stonetop-cg-pick{{/if}}{{#unless ../cgContext}} {{../inputClass}}{{/unless}}"
               {{#if ../radio}}name="{{../namePrefix}}-{{../rowKey}}"{{/if}}
               {{#if ../cgContext}}
               data-cg-context="{{../cgContext}}"
               data-cg-group="{{../cgGroup}}"
               data-cg-option="{{slug}}"
               data-cg-siblings="{{../siblingSlugsCsv}}"
               data-display-label="{{text}}"
               {{else}}
               {{#if ../possessionSlug}}data-possession-slug="{{../possessionSlug}}"{{/if}}
               {{#if ../siblingSlugsCsv}}data-sibling-slugs-csv="{{../siblingSlugsCsv}}"{{/if}}
               data-row-key="{{../rowKey}}"
               data-choice-slug="{{slug}}"
               {{/if}}
               {{#if checked}}checked{{/if}}>
        {{#if (eq type "input")}}
        <input type="text"
               class="stonetop-cg-text"
               data-cg-context="{{../cgContext}}"
               data-cg-group="{{../cgGroup}}"
               data-cg-option="{{slug}}-fill"
               value="{{fillValue}}">
        {{else}}
        {{text}}
        {{/if}}
    </label>
    {{/if}}
    {{/each}}
</div>
{{/if}}
